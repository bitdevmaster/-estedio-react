# @estedio/react — environment variable reference
# Copy this file to .env.local and fill in your values.
# These variables are read automatically by getLibConfig() at runtime.
# ESTEDIO_* takes precedence over NEXT_PUBLIC_* when both are present.

# ─── API ──────────────────────────────────────────────────────────────────────

# Base URL prepended to all resource endpoints (required)
ESTEDIO_API_BASE_URL=https://api.example.com
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Endpoint called to refresh an expired access token (default: /auth/refresh)
ESTEDIO_REFRESH_ENDPOINT=/auth/refresh
# NEXT_PUBLIC_REFRESH_ENDPOINT=/auth/refresh

# ─── Auth token storage keys ──────────────────────────────────────────────────

# Storage key used to read/write the JWT access token (default: access_token)
ESTEDIO_ACCESS_TOKEN_KEY=access_token
# NEXT_PUBLIC_ACCESS_TOKEN_KEY=access_token

# Storage key used to read/write the JWT refresh token (default: refresh_token)
ESTEDIO_REFRESH_TOKEN_KEY=refresh_token
# NEXT_PUBLIC_REFRESH_TOKEN_KEY=refresh_token

# ─── Encrypted storage ────────────────────────────────────────────────────────

# AES-GCM encryption secret for localStorage / sessionStorage persistence.
# IMPORTANT: set a strong random value in production.
# Generate one with: openssl rand -hex 32
ESTEDIO_STORAGE_SECRET=replace-this-in-production
# NEXT_PUBLIC_STORAGE_SECRET=replace-this-in-production
