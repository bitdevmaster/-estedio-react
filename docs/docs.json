{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "estedio/react",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "configuration"]
          },
          {
            "group": "Adapters",
            "pages": [
              "adapters/overview",
              "adapters/redux",
              "adapters/zustand",
              "adapters/tanstack-query"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "core/http-client",
              "core/storage",
              "core/token-management"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Core API",
            "pages": ["api-reference/core"]
          },
          {
            "group": "Adapter APIs",
            "pages": [
              "api-reference/redux",
              "api-reference/zustand",
              "api-reference/tanstack-query"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/bitdevmaster/-estedio-react",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/@estedio/react",
          "icon": "package"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://github.com/bitdevmaster/-estedio-react/issues"
      }
    ],
    "primary": {
      "type": "button",
      "label": "npm",
      "href": "https://www.npmjs.com/package/@estedio/react"
    }
  },
  "contextual": {
